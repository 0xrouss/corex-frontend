# From https://dashboard.reown.com — required for AppKit / WalletConnect
NEXT_PUBLIC_PROJECT_ID=

# Optional: must match your deployed origin for wallet verification (defaults to http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: read API bind exposed by the running Corex extension
NEXT_PUBLIC_API_URL=http://127.0.0.1:6680

# Optional server-side overrides for the Corex write flow
COREX_PROXY_URL=http://127.0.0.1:6676
COREX_DEPLOYMENT_FILE=../corex-tee/config/coston2/corex-deployment.json
COREX_FEE_WEI=1000000000000
